{
  "name": "alo-iot-chatbot",
  "version": "1.0.0",
  "description": "Grameenphone Alo IoT Product Chatbot \u2014 5-node pipeline with RAG",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "scrape": "ts-node scripts/scrape.ts --run-now",
    "scrape:watch": "ts-node scripts/scrape.ts",
    "test": "ts-node src/test.ts",
    "client": "vite --config vite.config.ts",
    "typecheck": "tsc --noEmit",
    "build:client": "vite build --config vite.config.ts"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.9.0",
    "@libsql/client": "0.4.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.0.0",
    "apache-arrow": "^16.0.0",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "openai": "^4.28.0",
    "pdf.js-extract": "^0.2.1",
    "playwright": "^1.59.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "uuid": "^9.0.0",
    "vite": "^5.0.0"
  },
  "devDependencies": {}
}
