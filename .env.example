# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── OpenAI (LLM + embeddings) ──────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Turso (session storage + scrape hashes) ────────────────────────────────────
TURSO_DATABASE_URL=libsql://alo-chatbot-yourname.aws-us-east-1.turso.io
TURSO_AUTH_TOKEN=your_turso_token_here

# ── LanceDB (local vector DB — no Docker needed) ───────────────────────────────
# Leave blank to use default: data/lancedb/
LANCEDB_PATH=

# ── Express server ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
